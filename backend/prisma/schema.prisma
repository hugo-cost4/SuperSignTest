generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["supersign"]
}

enum Status {
  PENDENTE
  ASSINADO

  @@schema("supersign")
}

model Documento {
  id        String   @id @default(uuid())
  titulo    String
  descricao String
  status    Status   @default(PENDENTE)
  criadoEm  DateTime @default(now()) @map("criado_em")

  @@map("documentos")
  @@schema("supersign")
}
